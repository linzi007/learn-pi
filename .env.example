# 模型课程的 code.ts 默认调用真实模型：
#   npm run lesson -- s01
#
# 可以直接复用同级 learn-claude-code/.env，或设置：
#   LEARN_PI_ENV_FILE=../learn-claude-code/.env

# Anthropic API Key，或 Anthropic-compatible provider 的 API Key。
ANTHROPIC_API_KEY=

# 可选。未设置时使用 claude-haiku-4-5。
MODEL_ID=claude-haiku-4-5

# 可选。未设置时使用 https://api.anthropic.com。
# ANTHROPIC_BASE_URL=
