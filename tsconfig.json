{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"lib": ["ES2022"],
		"types": ["node"],
		"strict": true,
		"erasableSyntaxOnly": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["lessons/**/*.ts", "scripts/**/*.ts", "src/**/*.ts"]
}
